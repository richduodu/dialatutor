rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DIAL A TUTOR - SECURITY RULES DOCUMENTATION
     *
     * Core Philosophy:
     * This ruleset enforces a strict path-based ownership model for all student-specific data.
     * The primary goal is to ensure that students can only access and modify their own 
     * educational progress, while allowing for public verification of learning outcomes.
     *
     * Data Structure:
     * - /students/{studentId}: Root student profiles.
     * - /students/{studentId}/lessonAttempts: Individual lesson responses and AI grades.
     * - /students/{studentId}/proofsOfLearning: Private blockchain-linked certificates.
     * - /students/{studentId}/studentReports: Progress summaries sent via SMS/Email.
     * - /lessons: Global, read-only educational content.
     * - /proofsOfLearning_public: A flattened, public collection for verification.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Combines ownership check with existence check for updates and deletes
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for student profile management. 
     */
    match /students/{studentId} {
      allow list: if isSignedIn();
      allow get: if isOwner(studentId);
      allow create: if isOwner(studentId) && request.resource.data.id == studentId;
      allow update, delete: if isExistingOwner(studentId);

      /**
       * @description Records of specific lesson attempts.
       */
      match /lessonAttempts/{attemptId} {
        allow get, list: if isOwner(studentId);
        allow create: if isOwner(studentId) && request.resource.data.studentId == studentId;
        allow update: if isExistingOwner(studentId) && request.resource.data.studentId == resource.data.studentId;
        allow delete: if isExistingOwner(studentId);
      }

      /**
       * @description Private copies of Proof of Learning tokens.
       */
      match /proofsOfLearning/{proofId} {
        allow get, list: if isOwner(studentId);
        allow create: if isOwner(studentId) && request.resource.data.studentId == studentId;
        allow update: if isExistingOwner(studentId) && request.resource.data.studentId == resource.data.studentId;
        allow delete: if isExistingOwner(studentId);
      }

      /**
       * @description Comprehensive progress reports.
       */
      match /studentReports/{reportId} {
        allow get, list: if isOwner(studentId);
        allow create: if isOwner(studentId) && request.resource.data.studentId == studentId;
        allow update: if isExistingOwner(studentId) && request.resource.data.studentId == resource.data.studentId;
        allow delete: if isExistingOwner(studentId);
      }
    }

    /**
     * @description Global educational content.
     */
    match /lessons/{lessonId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Publicly accessible collection of minted Proofs for verification.
     */
    match /proofsOfLearning_public/{proofId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.studentId;
      allow update: if isExistingOwner(resource.data.studentId) && request.resource.data.studentId == resource.data.studentId;
      allow delete: if isExistingOwner(resource.data.studentId);
    }
  }
}